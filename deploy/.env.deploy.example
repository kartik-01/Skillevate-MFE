# Copy to `.env.deploy` in this folder (`deploy/`) and fill in production values.
# `docker-compose.yml` passes these through as Dockerfile build-args (webpack inlines API + remote URLs at build time).
#
# For local smoke tests leave REMOTE_* as http://localhost:8081-style URLs matching the host port mappings below.

# --- Ports on your machine (host) -> container :80 ---
HOST_APP_SHELL_PORT=8080
HOST_RECOMMENDATION_PORT=8081
HOST_GAMIFY_PORT=8082
HOST_ANALYSIS_PORT=8083

# --- Module Federation: public origins of each remote (no trailing slash) ---
# Example with subdomains on DigitalOcean:
# REMOTE_RECOMMENDATION_URL=https://recommend.yourdomain.com
# REMOTE_GAMIFY_URL=https://gamify.yourdomain.com
# REMOTE_ANALYSIS_URL=https://analysis.yourdomain.com
REMOTE_RECOMMENDATION_URL=http://localhost:8081
REMOTE_GAMIFY_URL=http://localhost:8082
REMOTE_ANALYSIS_URL=http://localhost:8083

# --- Backend APIs (match your deployed FastAPI / other services) ---
USER_SERVICE_URL=https://api-users.example.com
ANALYSIS_API_BASE_URL=https://api-analyses.example.com
ANALYSIS_API_PATH_ROOT=/api
ANALYSIS_DEFAULT_INFERENCE=rag
ANALYSIS_RESUME_PARSER_INFERENCE=ollama
SKILLEVATE_RECOMMENDATION_URL=https://api-rec.example.com/api/batch-recommendations
SKILLEVATE_GAMIFICATION_URL=https://api-gamify.example.com

AUTH0_AUDIENCE=
