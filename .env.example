# ---------------------------------------------------------------------------
# Skillevate MFE — environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` (next to it) and adjust values for your machine.
# Both files are read by `configs/env.js` at build time and the values are
# inlined into the React bundle via webpack's `DefinePlugin`. Anything set in
# the shell (or via `cross-env`) takes precedence over `.env`, so CI can
# override these without touching disk.
#
# After changing `.env`, restart any running `pnpm dev:*` process so webpack
# re-reads it.
# ---------------------------------------------------------------------------

# ----- Backend microservices the React apps talk to ------------------------
# Skillevate User service (FastAPI). app-shell uses this for profile + prefs.
USER_SERVICE_URL=http://localhost:8000

# Skillevate Analyses service (FastAPI). Used by the analysis MFE.
ANALYSIS_API_BASE_URL=http://localhost:8001
# URL path prefix mounted by skillevate-analyses (see main.py router prefixes).
ANALYSIS_API_PATH_ROOT=/api
# Default `inference` value for JD extraction / analysis requests (e.g. rag, ollama).
ANALYSIS_DEFAULT_INFERENCE=rag
# Resume `/api/.../resume/skills` form `inference` (ollama | groq | none per backend).
ANALYSIS_RESUME_PARSER_INFERENCE=ollama

# Skillevate Recommendation service. Note the path component.
SKILLEVATE_RECOMMENDATION_URL=http://localhost:8002/api/batch-recommendations

# Skillevate Gamification service.
SKILLEVATE_GAMIFICATION_URL=http://localhost:8003

# ----- Module Federation remote dev-server URLs ----------------------------
# app-shell embeds these at build time so it knows where to fetch each
# remoteEntry.js. Match the ports in package.json's `dev:*` scripts.
REMOTE_RECOMMENDATION_URL=http://localhost:3001
REMOTE_GAMIFY_URL=http://localhost:3002
REMOTE_ANALYSIS_URL=http://localhost:3003

# ----- Cross-MFE host reload trigger ---------------------------------------
# Each remote pings this URL when it finishes a rebuild so the host shell
# can reload the page. Leave blank to disable.
HOST_RELOAD_URL=http://localhost:3000/__trigger_reload__

# ----- Auth0 ---------------------------------------------------------------
# Optional API audience. Leave blank when no Auth0 API is configured — the
# AuthProvider then issues plain ID-tokens and the User service runs without
# JWT verification.
AUTH0_AUDIENCE=
